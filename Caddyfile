# HTTP only — avoids broken HTTPS redirects for localhost (TLS would need a real cert or mkcert).
# Service names match docker-compose: `app` (Next.js), `storage` (MinIO).
http://:80 {
	# MinIO public objects (paths stored in DB as /minio/notra/...)
	handle_path /minio/* {
		reverse_proxy storage:9000
	}

	reverse_proxy app:3000
}
